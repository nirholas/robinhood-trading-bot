# ---------------------------------------------------------------------------
# robinhood-trading-bot environment (Robinhood Chain, chain ID 4663)
# Copy to .env and fill in. Everything is optional for paper mode: the bot
# reads the public chain RPC and simulates fills at real quoted prices.
# ---------------------------------------------------------------------------

# Trading mode. Live trading is triple-gated: ALL THREE of
#   MODE=live
#   LIVE_TRADING=1
#   ROBINHOOD_CHAIN_PRIVATE_KEY=0x...
# must be set or the bot stays in paper mode.
MODE=paper
LIVE_TRADING=0

# The trading wallet's private key (0x-prefixed, 32 bytes hex).
# Generate a fresh one with: npx rhbot keygen
# Fund it with ETH on Robinhood Chain (bridge via https://jumper.exchange)
# and wrap some into WETH; buys spend WETH, sells return WETH.
# Use a burner wallet sized to what you are willing to lose.
# ROBINHOOD_CHAIN_PRIVATE_KEY=

# Custom RPC endpoint (defaults to the chain's public RPC).
# ROBINHOOD_CHAIN_RPC_URL=

# Max slippage for live swaps, basis points (300 = 3%).
SLIPPAGE_BPS=300

# Paper trading starting balance (USD)
PAPER_STARTING_USD=1000

# Web dashboard
PORT=8788
HOST=127.0.0.1
# Auth token for the dashboard + HTTP API. Generated and printed on first
# start if unset. Set your own to keep it stable across restarts.
# DASH_TOKEN=

# Telegram alerts + remote commands (optional). Create a bot with @BotFather.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Where the SQLite database and config live (default: ./data)
# RHBOT_DATA_DIR=./data
