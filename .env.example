# ---------------------------------------------------------------------------
# robinhood-trading-bot environment
# Copy to .env and fill in. Everything except the Robinhood keys is optional:
# without keys the bot runs fully in paper mode against live market data.
# ---------------------------------------------------------------------------

# Robinhood Crypto API credentials (https://robinhood.com/account/crypto -> API)
# Generate a keypair with: npx robinhood-mcp robinhood-keygen
ROBINHOOD_CRYPTO_API_KEY=
ROBINHOOD_CRYPTO_PRIVATE_KEY=

# Live trading is triple-gated. All three must be set for real orders:
#   MODE=live                        (bot-level switch, default: paper)
#   ROBINHOOD_CRYPTO_ENABLE_TRADING=1 (execution-layer switch)
#   credentials above
MODE=paper
ROBINHOOD_CRYPTO_ENABLE_TRADING=0

# Hard spend caps enforced at the execution layer (USD)
ROBINHOOD_CRYPTO_MAX_ORDER_USD=100
ROBINHOOD_CRYPTO_MAX_DAILY_USD=500

# Optional: restrict live trading to specific symbols (comma-separated)
# ROBINHOOD_CRYPTO_SYMBOL_ALLOWLIST=BTC-USD,ETH-USD,SOL-USD

# Optional: block all sell orders at the execution layer
# ROBINHOOD_CRYPTO_BUY_ONLY=1

# Paper trading starting balance (USD)
PAPER_STARTING_USD=1000

# Solana RPC used for wallet tracking and holder analysis.
# The public endpoint works but is heavily rate limited; a Helius/QuickNode/
# Triton URL is strongly recommended when tracking more than 1-2 wallets.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Web dashboard
PORT=8788
HOST=127.0.0.1
# Auth token for the dashboard + HTTP API. Generated and printed on first
# start if unset. Set your own to keep it stable across restarts.
# DASH_TOKEN=

# Telegram alerts + remote commands (optional). Create a bot with @BotFather.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Where the SQLite database and config live (default: ./data)
# RHBOT_DATA_DIR=./data
